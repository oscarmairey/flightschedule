// FlightSchedule — Prisma schema
// All durations stored as Int (minutes). Display as HH:MM only.
// Transaction table is the source of truth for HDV.
// UserFlightHourBalance is denormalized per-type for read performance.
// Every HDV mutation MUST insert a Transaction in the same DB transaction.
//
// V2 inversion: HDV is debited at FLIGHT submission (FLIGHT_DEBIT), not at
// reservation booking. Reservations are scheduling blocks with no HDV impact.
// Bloc OFF / bloc ON engine times on the Flight model are required and drive
// the actual flown duration. See CLAUDE.md rules #3, #3b, #4, #7, #8, #9.
//
// V2.4 — per-type HDV wallets (FlightHourType). Packages and transactions
// are scoped to a FlightHourType. A pilot may only hold a non-zero balance
// in ONE type at a time (single-active-type invariant, enforced in
// applyHdvMutation). Flight debits auto-route to the pilot's currently
// active type.
//
// Reference: PRD.md §4 and CLAUDE.md architectural rules.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────

enum Role {
  PILOT
  ADMIN
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED_BY_PILOT
  CANCELLED_BY_ADMIN
}

enum TransactionType {
  PACKAGE_PURCHASE
  FLIGHT_DEBIT
  CANCELLATION_REFUND
  ADMIN_ADJUSTMENT
  BANK_TRANSFER
}

// Lifecycle of a bank-transfer request submitted by a pilot.
// PENDING  → awaiting admin review (pilot has declared the wire was sent)
// VALIDATED → admin confirmed incoming wire; a Transaction was created
// REJECTED → admin refused (wrong amount, never received, etc.)
enum BankTransferStatus {
  PENDING
  VALIDATED
  REJECTED
}

// ─── Models ─────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique
  name           String
  passwordHash   String
  role           Role     @default(PILOT)
  isActive       Boolean  @default(true)
  mustResetPw    Boolean  @default(true)
  // Stripe Customer ID — created on first inline card payment so the
  // pilot can reuse saved cards. Null until the first card purchase.
  stripeCustomerId String? @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastLoginAt    DateTime?

  // Relations
  reservations              Reservation[]            @relation("UserReservations")
  cancelledReservations     Reservation[]            @relation("ReservationCancelledBy")
  flights                   Flight[]
  transactions              Transaction[]            @relation("UserTransactions")
  performedTransactions     Transaction[]            @relation("TransactionPerformedBy")
  createdAvailabilityBlocks AvailabilityBlock[]
  createdOpenPeriods        OpenPeriod[]
  bankTransfers             BankTransfer[]           @relation("UserBankTransfers")
  reviewedBankTransfers     BankTransfer[]           @relation("BankTransferReviewedBy")
  updatedBankAccounts       BankAccount[]            @relation("BankAccountUpdatedBy")
  hourBalances              UserFlightHourBalance[]

  @@index([email])
  @@index([isActive])
}

model Reservation {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid
  user            User              @relation("UserReservations", fields: [userId], references: [id])

  // Use full DateTime for precise conflict detection and ordering.
  // Both stored as UTC; display layer converts to Europe/Paris.
  startsAt        DateTime
  endsAt          DateTime

  // Denormalized convenience for list views — equals (endsAt - startsAt)
  // in minutes. V2 reservations have no HDV impact, so there is no
  // hdvDeductedMin snapshot anymore.
  durationMin     Int
  // Pilot-supplied context shown in the calendar + upcoming lists
  // (e.g. "Corsica trip", "License renewal"). Purely informational.
  comment         String?
  // Rough estimate shown in the calendar + upcoming lists. Stored as a
  // decimal hour value with 2 fractional digits, independent from the
  // scheduled slot duration.
  estimatedFlightHours Decimal?     @db.Decimal(6, 2)

  status          ReservationStatus @default(CONFIRMED)
  cancelledAt     DateTime?
  cancelledById   String?           @db.Uuid
  cancelledBy     User?             @relation("ReservationCancelledBy", fields: [cancelledById], references: [id])

  // True iff the reservation was created server-side at flight-submission
  // time for an "on the go" flight (the pilot didn't book in advance).
  // Auto-created reservations cannot be cancelled — the underlying flight
  // is the source of truth and flights are immutable. See CLAUDE.md rule #7.
  autoCreatedFromFlight Boolean      @default(false)

  transactions    Transaction[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([startsAt])
  @@index([status, startsAt])
}

model Flight {
  id                       String       @id @default(uuid()) @db.Uuid
  userId                   String       @db.Uuid
  user                     User         @relation(fields: [userId], references: [id])

  // V2.2: flights are standalone log entries — no reservation link.
  // The Flight→Reservation FK was dropped in the
  // `drop_flight_reservation_link` migration.

  // Paris-local date of `engineStart`. Used for logbook listing + the YTD
  // aggregate. Cross-midnight flights (rare) keep the bloc-OFF date.
  date                     DateTime     @db.Date
  depAirport               String       // ICAO, e.g. "LFPN"
  arrAirport               String       // ICAO

  // Actual flown duration in minutes — server-computed from
  // `(engineStop − engineStart)` with cross-midnight handling. The flight
  // is the V2 unit of HDV consumption: a `FLIGHT_DEBIT` Transaction with
  // `amountMin = -actualDurationMin` is inserted in the same DB transaction
  // as the Flight. Negative balances are allowed (admin reconciles).
  // See CLAUDE.md rules #3b and #9.
  actualDurationMin        Int

  // Engine bloc OFF / bloc ON times stored as "HH:MM" strings paired with
  // `date`. Required since they drive `actualDurationMin`. No timezone
  // math (the date column carries the day, the strings carry the wall
  // clock).
  engineStart              String       @db.VarChar(5)
  engineStop               String       @db.VarChar(5)

  // Tachymeter (hour-meter) readings at bloc OFF / bloc ON, stored as
  // hundredths of an hour to stay integer-only per rule #1 (e.g. the
  // user-facing value "1234.56 h" is persisted as 123456).
  // Optional: historic flights predate the field, and not every
  // aircraft has a tach reading worth recording.
  tachyStartHundredths     Int?
  tachyStopHundredths      Int?

  landings                 Int          @default(1)
  remarks                  String?

  // Cloudflare R2 object keys, e.g. ["flights/{id}/photo_1.jpg", ...]
  // The app server NEVER transits photo bytes — uploads go browser → R2 directly.
  // V2: photos are OPTIONAL (0–5 per flight). See CLAUDE.md rule #6.
  photos                   String[]

  transactions             Transaction[]

  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@index([userId])
  @@index([date])
}

model Transaction {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @db.Uuid
  user            User            @relation("UserTransactions", fields: [userId], references: [id])

  type            TransactionType
  // Signed: positive = credit, negative = debit. Always in minutes.
  amountMin       Int
  // Snapshot of the TYPE-SCOPED balance AFTER this transaction was applied
  // (i.e. UserFlightHourBalance[userId, flightHourTypeId].balanceMin post-apply).
  // Enables point-in-time reconstruction without replaying full history.
  // V2.4: used to be global before per-type wallets landed.
  balanceAfterMin Int

  // FlightHourType this transaction belongs to. Required on every row:
  // package purchases and bank transfers inherit the Package's type, flight
  // debits inherit the user's currently active type, admin adjustments pick
  // a type in the form, cancellation refunds mirror the original.
  flightHourTypeId String         @db.Uuid
  flightHourType   FlightHourType @relation(fields: [flightHourTypeId], references: [id])

  // EUR price in cents AT THE TIME of the transaction. Populated by the
  // Stripe webhook on PACKAGE_PURCHASE (from session.amount_total) so the
  // admin pilot table can compute "Montant dépensé" without joining Stripe.
  // Null for non-purchase transactions and for legacy purchases predating
  // V2 (no historical fill).
  priceCents      Int?

  // External reference — Stripe session ID, admin reason text, etc.
  // Used for idempotency on PACKAGE_PURCHASE (check before crediting).
  reference       String?

  // Optional links to the entity that caused this transaction.
  flightId        String?         @db.Uuid
  flight          Flight?         @relation(fields: [flightId], references: [id])
  reservationId   String?         @db.Uuid
  reservation     Reservation?    @relation(fields: [reservationId], references: [id])

  // Who triggered the transaction — self for self-service actions,
  // admin user id for admin-initiated changes.
  performedById   String          @db.Uuid
  performedBy     User            @relation("TransactionPerformedBy", fields: [performedById], references: [id])

  // Reverse relation to BankTransfer (set when an admin validates a
  // pending wire and the resulting Transaction is materialised).
  bankTransfer    BankTransfer?

  createdAt       DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([userId, flightHourTypeId, createdAt])
  @@index([type])
  @@index([flightHourTypeId])
  @@index([reference]) // for Stripe session ID idempotency lookups
}

model AvailabilityBlock {
  id            String           @id @default(uuid()) @db.Uuid

  // V2 inversion (CLAUDE.md rule #8): the aircraft is available 24/7 by
  // default. Every AvailabilityBlock row represents an UNAVAILABILITY
  // exception. The AvailabilityType enum has been removed.
  //
  // Dual-key system:
  //   - dayOfWeek (0-6) for recurring weekly exceptions
  //   - specificDate for one-off exceptions (takes precedence)
  // Exactly one of dayOfWeek / specificDate must be set; enforced in app code.
  dayOfWeek     Int?             // 0 = Sunday … 6 = Saturday
  specificDate  DateTime?        @db.Date

  // Time-of-day stored as minutes since midnight (0–1440).
  // Consistent with the "everything in minutes" rule.
  startMinutes  Int
  endMinutes    Int

  reason        String?

  createdById   String           @db.Uuid
  createdBy     User             @relation(fields: [createdById], references: [id])

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([dayOfWeek])
  @@index([specificDate])
}

// V2 — date-range "open periods" defining when the aircraft is bookable.
// The aircraft is fully reservable (24/7) inside any OpenPeriod, EXCEPT
// where an `AvailabilityBlock` exception (recurring or per-date) blocks it.
//
// Special case: if NO OpenPeriod rows exist, the aircraft is treated as
// always open. This avoids breaking the booking flow on a fresh install
// before the operator has defined any opening seasons.
model OpenPeriod {
  id          String   @id @default(uuid()) @db.Uuid
  // Both inclusive — `endDate` is the last bookable day.
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  reason      String?

  createdById String   @db.Uuid
  createdBy   User     @relation(fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startDate])
  @@index([endDate])
}

// V2 — Stripe HDV packages, mirrored in our DB so admin CRUD on /admin/tarifs
// can drive Stripe Product/Price create/update/archive. The pilot purchase
// flow on /dashboard reads from this table directly. See plan §12.
//
// Soft-delete only (`isActive = false`) — historical PACKAGE_PURCHASE
// transactions keep their join target via `flyPackageId` Stripe metadata.
model Package {
  id              String   @id @default(uuid()) @db.Uuid
  stripeProductId String   @unique
  stripePriceId   String   @unique
  name            String
  description     String?
  // Price excluding VAT, in EUR cents. Stripe Tax adds 20% French VAT at
  // checkout when `tax_behavior = "exclusive"` on the Stripe Price.
  priceCentsHT    Int
  // HDV minutes credited on a successful purchase. Stamped into Stripe
  // checkout session metadata (`flyHdvMin`) and read by the webhook.
  hdvMinutes      Int
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  // V2.4 — required FlightHourType FK. Every package belongs to exactly
  // one type; the checkout webhook uses this to credit the right wallet.
  flightHourTypeId String         @db.Uuid
  flightHourType   FlightHourType @relation(fields: [flightHourTypeId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([flightHourTypeId])
}

// V2.1 — Association bank account (single-row table managed by admins).
// The pilot bank-transfer modal on /dashboard displays the latest row
// verbatim, so updates take effect immediately without any caching.
model BankAccount {
  id           String   @id @default(uuid()) @db.Uuid
  iban         String
  bic          String
  holderName   String
  bankName     String?
  instructions String?

  updatedById  String   @db.Uuid
  updatedBy    User     @relation("BankAccountUpdatedBy", fields: [updatedById], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// V2.1 — Pilot-initiated bank-transfer request awaiting admin review.
// This table is NOT a ledger. It holds PENDING intentions plus historical
// REJECTED rows. On VALIDATED, `applyHdvMutation` creates a real
// `Transaction` row and we link it via `transactionId` — the Transaction
// ledger remains the single source of truth for HDV balances (rule #2).
model BankTransfer {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @db.Uuid
  user          User               @relation("UserBankTransfers", fields: [userId], references: [id])

  // Snapshot of the package at creation time — the admin still grants
  // exactly these HDV minutes even if the Package row is edited later.
  packageId     String             @db.Uuid
  packageName   String
  hdvMinutes    Int
  priceCentsTTC Int

  // Snapshot of the FlightHourType at creation time. The admin still
  // credits exactly this type on validation even if the Package's type
  // is changed later or the FlightHourType row is archived.
  flightHourTypeId   String         @db.Uuid
  flightHourType     FlightHourType @relation(fields: [flightHourTypeId], references: [id])
  flightHourTypeName String

  // "FS-XXXXXX" human-readable wire memo. Unique across the table so the
  // admin can match incoming wires unambiguously.
  reference     String             @unique

  status        BankTransferStatus @default(PENDING)

  // Populated on VALIDATED — links to the Transaction inserted by
  // applyHdvMutation. Unique so we can never double-credit.
  transactionId String?            @unique @db.Uuid
  transaction   Transaction?       @relation(fields: [transactionId], references: [id])

  // Who approved / refused, and when / why.
  reviewedById  String?            @db.Uuid
  reviewedBy    User?              @relation("BankTransferReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  rejectionNote String?

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@index([reference])
  @@index([flightHourTypeId])
}

// V2.4 — admin-managed "type" of HDV hour (e.g. École, Voyage, Local).
// Every Package, Transaction, and BankTransfer is scoped to exactly one
// FlightHourType. A pilot may only hold a non-zero balance in ONE type at
// a time (single-active-type invariant, enforced in applyHdvMutation).
// Soft-delete only via isActive=false — historical rows still reference it.
model FlightHourType {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packages      Package[]
  transactions  Transaction[]
  userBalances  UserFlightHourBalance[]
  bankTransfers BankTransfer[]

  @@index([isActive, name])
}

// V2.4 — per-type HDV wallet. Replaces the single denormalized
// `User.hdvBalanceMin` that existed before. Source of truth is still the
// Transaction ledger; this table caches the per-type sum for read speed.
//
// Rule #2 (updated): for every (userId, flightHourTypeId),
//   balanceMin = SUM(Transaction.amountMin WHERE userId, flightHourTypeId)
model UserFlightHourBalance {
  userId           String         @db.Uuid
  user             User           @relation(fields: [userId], references: [id])
  flightHourTypeId String         @db.Uuid
  flightHourType   FlightHourType @relation(fields: [flightHourTypeId], references: [id])
  balanceMin       Int            @default(0)
  updatedAt        DateTime       @updatedAt

  @@id([userId, flightHourTypeId])
  @@index([userId])
  @@index([flightHourTypeId])
}
