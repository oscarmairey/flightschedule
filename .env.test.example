# ════════════════════════════════════════════════════════════
# FlightSchedule — test environment (template)
# ════════════════════════════════════════════════════════════
# Copy to .env.test and keep as-is unless you have a reason to
# diverge. Integration tests assert that DATABASE_URL points at
# port 5443 and DB name `cavok_test` to prevent accidental writes
# against the dev or prod database.
# ════════════════════════════════════════════════════════════

DATABASE_URL="postgresql://cavok_test:cavok_test@127.0.0.1:5443/cavok_test?schema=public"

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:6100"
NODE_ENV="test"

# ─── NextAuth (test-only fixture secret) ─────────────────────
NEXTAUTH_URL="http://localhost:6100"
NEXTAUTH_SECRET="test-secret-do-not-use-in-production-00000000"

# ─── Stripe (test fixtures; signatures are HMAC'd locally) ───
STRIPE_PUBLISHABLE_KEY="pk_test_fixture"
STRIPE_SECRET_KEY="sk_test_fixture"
STRIPE_WEBHOOK_SECRET="whsec_test_fixture_secret"

# ─── R2 (mocked by tests/setup/mocks.ts) ─────────────────────
R2_ACCESS_KEY_ID="test"
R2_SECRET_ACCESS_KEY="test"
R2_BUCKET_NAME="cavok-flight-photos-test"
R2_ENDPOINT="https://r2.fake.test"

# ─── Resend (mocked) ─────────────────────────────────────────
RESEND_API_KEY="re_test"
RESEND_FROM_EMAIL="FlightSchedule Test <test@flightschedule.test>"

# ─── Admin bootstrap (used by prisma/seed.ts in e2e) ─────────
ADMIN_BOOTSTRAP_EMAIL="admin@test.local"
ADMIN_BOOTSTRAP_NAME="Test Admin"
ADMIN_BOOTSTRAP_PASSWORD="AdminTest123!"

# ─── Locale / timezone ───────────────────────────────────────
TZ="Europe/Paris"
APP_LOCALE="fr-FR"
