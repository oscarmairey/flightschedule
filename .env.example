# ════════════════════════════════════════════════════════════
# CAVOK Glass Cockpit — environment variables (template)
# ════════════════════════════════════════════════════════════
# Copy to .env and fill in real values. Never commit .env.
# ════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://cavok:CHANGE_ME@127.0.0.1:5442/cavok?schema=public"
DATABASE_URL_INTERNAL="postgresql://cavok:CHANGE_ME@db:5432/cavok?schema=public"
POSTGRES_USER="cavok"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="cavok"

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_STANDARD=""
STRIPE_PRICE_PREMIUM=""

# ─── Cloudflare R2 ───────────────────────────────────────────
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="cavok-flight-photos"
# S3-compatible API endpoint. The bucket is FULLY PRIVATE — no custom
# domain, no public r2.dev URL. Reads and writes both go through presigned
# URLs generated by the app server.
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"

# ─── Resend ──────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="CAVOK <noreply@cavok.ovh>"

# ─── Admin bootstrap (used by prisma/seed.ts) ────────────────
ADMIN_BOOTSTRAP_EMAIL="admin@example.com"
ADMIN_BOOTSTRAP_NAME="Admin Name"
ADMIN_BOOTSTRAP_PASSWORD="ChangeMe!"

# ─── Locale / timezone ───────────────────────────────────────
TZ="Europe/Paris"
APP_LOCALE="fr-FR"

# ─── DB backups (used by scripts/backup-db.sh) ───────────────
# Symmetric GPG passphrase for nightly Postgres dumps. Generate with:
#   openssl rand -base64 48
# The encrypted dumps are uploaded to bucket cavok-db-backups (must be
# fully private — same rule as the photo bucket).
BACKUP_PASSPHRASE=""
BACKUP_BUCKET="cavok-db-backups"
